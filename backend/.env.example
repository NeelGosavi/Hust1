# Copy this file to .env and fill in real values. Never commit .env.

# MongoDB Atlas connection string
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster0

# LLM provider — NaraRouter (OpenAI-compatible gateway, Claude/Mistral models)
NARA_API_KEY=sk-nry-your-nara-key
NARA_BASE_URL=https://router.bynara.id/v1
NARA_MODEL=claude-haiku-4.5

# Clerk backend secret key (server-side only)
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
